              { "key": "Content-Type", "value": "application/json", "type": "text" },
              { "key": "Accept", "value": "application/json", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"asesor1\",\n  \"pin\": \"123456\",\n  \"device_name\": \"Bruno\"\n}"
            },
            "url": "{{base_url}}/api/v1/cazador/auth/login"
